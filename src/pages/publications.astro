---
import BaseLayout from '../layouts/BaseLayout.astro';
import PublicationItem from '../components/PublicationItem.astro';
import publications from '../data/publications.json';

const byYear = new Map<number, typeof publications>();
for (const pub of [...publications].sort((a, b) => b.year - a.year)) {
  if (!byYear.has(pub.year)) byYear.set(pub.year, []);
  byYear.get(pub.year)!.push(pub);
}
---

<BaseLayout title="Publications" description="Academic publications and research contributions.">
  <div class="container">
    <header class="page-header">
      <p class="eyebrow">Research</p>
      <h1>Publications</h1>
      <p class="lede">
        {publications.length} publication{publications.length === 1 ? '' : 's'}, grouped by year.
      </p>
    </header>

    {[...byYear.entries()].map(([year, pubs]) => (
      <section class="year-group">
        <h2 class="year-heading"><span>{year}</span></h2>
        {pubs.map((pub) => <PublicationItem pub={pub} showYear={false} />)}
      </section>
    ))}
  </div>
</BaseLayout>

<style>
  .year-group { margin-bottom: 2.4rem; }
  .year-heading {
    display: flex;
    align-items: center;
    gap: 1rem;
    font-size: 1.35rem;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 0.5rem;
    font-variant-numeric: tabular-nums;
  }
  .year-heading::after {
    content: '';
    flex: 1;
    height: 1px;
    background: linear-gradient(to right, var(--border-strong), transparent);
  }
</style>
