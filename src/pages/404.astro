---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found">
  <div class="container notfound">
    <h1>404</h1>
    <p class="muted">Sorry, this page does not exist.</p>
    <p><a class="btn btn-primary" href="/">Back to home</a></p>
  </div>
</BaseLayout>

<style>
  .notfound {
    text-align: center;
    padding: 7rem 0 4rem;
  }
  .notfound h1 {
    font-size: 5rem;
    color: var(--accent);
  }
  .notfound p { margin-top: 0.8rem; }
</style>
