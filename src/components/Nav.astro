---
import Icon from './Icon.astro';
import profile from '../data/profile.json';

const links = [
  { href: '/#about', label: 'About' },
  { href: '/#news', label: 'News' },
  { href: '/publications/', label: 'Publications' },
  { href: '/projects/', label: 'Projects' },
  { href: '/blog/', label: 'Blog' },
];
const firstName = profile.name.split(' ').at(-1);
const path = Astro.url.pathname;
const isCurrent = (href: string) => !href.includes('#') && path.startsWith(href.replace(/\/$/, ''));
---

<header class="nav-wrap">
  <nav class="container-wide nav">
    <a href="/" class="brand">{firstName}<span class="brand-dot">.</span></a>

    <button class="menu-btn" aria-label="Open navigation menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>

    <div class="nav-right">
      <ul class="nav-links">
        {links.map((l) => (
          <li>
            <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
          </li>
        ))}
      </ul>
      <button class="theme-toggle" aria-label="Toggle dark mode" title="Toggle dark mode">
        <span class="icon-sun"><Icon name="sun" size={17} /></span>
        <span class="icon-moon"><Icon name="moon" size={16} /></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 78%, transparent);
    backdrop-filter: blur(12px) saturate(1.4);
    -webkit-backdrop-filter: blur(12px) saturate(1.4);
    border-bottom: 1px solid transparent;
    transition: border-color 0.25s ease, box-shadow 0.25s ease;
  }
  .nav-wrap.scrolled {
    border-bottom-color: var(--border);
    box-shadow: 0 4px 20px -8px rgba(0, 0, 0, 0.08);
  }
  :global(:root[data-theme='dark']) .nav-wrap.scrolled {
    box-shadow: 0 4px 20px -8px rgba(0, 0, 0, 0.5);
  }
  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 3.7rem;
  }
  .brand {
    font-family: var(--font-serif);
    font-size: 1.35rem;
    font-weight: 640;
    letter-spacing: -0.01em;
    color: var(--text);
  }
  .brand:hover { text-decoration: none; }
  .brand-dot { color: var(--accent); }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.1rem;
  }
  .nav-links {
    display: flex;
    gap: 0.3rem;
    list-style: none;
  }
  .nav-links a {
    display: inline-block;
    padding: 0.32rem 0.72rem;
    border-radius: 8px;
    color: var(--text-muted);
    font-size: 0.9rem;
    font-weight: 540;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .nav-links a:hover {
    color: var(--accent);
    background: var(--accent-soft);
    text-decoration: none;
  }
  .nav-links a[aria-current='page'] {
    color: var(--accent);
    background: var(--accent-soft);
  }

  .theme-toggle {
    display: grid;
    place-items: center;
    width: 2.15rem;
    height: 2.15rem;
    border-radius: 9px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease, transform 0.15s ease;
  }
  .theme-toggle:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    transform: rotate(12deg);
  }
  .icon-sun, .icon-moon { display: none; line-height: 0; }
  :global(:root[data-theme='dark']) .icon-sun { display: block; }
  :global(:root[data-theme='light']) .icon-moon { display: block; }

  .menu-btn {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 4px;
    width: 2.1rem;
    height: 2.1rem;
    background: none;
    border: none;
    cursor: pointer;
  }
  .menu-btn span {
    display: block;
    height: 2px;
    width: 20px;
    margin: 0 auto;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  @media (max-width: 640px) {
    .menu-btn { display: flex; }
    .nav-right {
      position: absolute;
      top: 3.7rem;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--border);
      padding: 0.5rem 1.4rem 1.1rem;
      display: none;
      box-shadow: 0 16px 30px -12px rgba(0, 0, 0, 0.15);
    }
    .nav-wrap.open .nav-right { display: flex; }
    .nav-wrap.open .menu-btn span:nth-child(1) { transform: translateY(6px) rotate(45deg); }
    .nav-wrap.open .menu-btn span:nth-child(2) { opacity: 0; }
    .nav-wrap.open .menu-btn span:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
    .nav-links {
      flex-direction: column;
      gap: 0;
    }
    .nav-links a {
      display: block;
      padding: 0.65rem 0.4rem;
      font-size: 1rem;
      border-radius: 6px;
    }
    .theme-toggle { margin-top: 0.6rem; }
  }
</style>

<script>
  const toggle = document.querySelector('.theme-toggle');
  toggle?.addEventListener('click', () => {
    const root = document.documentElement;
    const next = root.dataset.theme === 'dark' ? 'light' : 'dark';
    root.dataset.theme = next;
    localStorage.setItem('theme', next);
  });

  const wrap = document.querySelector('.nav-wrap');
  const menuBtn = document.querySelector('.menu-btn');
  menuBtn?.addEventListener('click', () => {
    const open = wrap?.classList.toggle('open');
    menuBtn.setAttribute('aria-expanded', String(!!open));
  });
  document.querySelectorAll('.nav-links a').forEach((a) =>
    a.addEventListener('click', () => wrap?.classList.remove('open'))
  );

  const onScroll = () => wrap?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });
</script>
