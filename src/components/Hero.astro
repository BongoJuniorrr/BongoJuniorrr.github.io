---
import Icon from './Icon.astro';
import profile from '../data/profile.json';
---

<section class="hero">
  <div class="container-wide hero-inner">
    <div class="hero-avatar-wrap">
      <img class="hero-avatar" src={profile.avatar} alt={profile.name} width="180" height="180" />
    </div>
    <div class="hero-text">
      <p class="eyebrow hero-hello">Hello, I am</p>
      <h1 class="hero-name">{profile.name}</h1>
      <p class="hero-tagline">{profile.tagline}</p>
      <p class="hero-affiliation">
        <em>{profile.affiliation}</em><span class="hero-sep">·</span>{profile.location}
      </p>
      <div class="hero-actions">
        <a class="btn btn-primary" href={profile.cv} target="_blank" rel="noopener">
          <Icon name="pdf" size={16} /> Download CV
        </a>
        <span class="hero-social-row">
          {profile.social.map((s) => (
            <a
              class="hero-social"
              href={s.url}
              target={s.platform === 'email' ? undefined : '_blank'}
              rel="noopener"
              aria-label={s.label}
              title={s.label}
            >
              <Icon name={s.platform} size={19} />
            </a>
          ))}
        </span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: 5.2rem 0 3.6rem;
    border-bottom: 1px solid var(--border);
    overflow: hidden;
    background: radial-gradient(42rem 22rem at 85% -6rem, var(--accent-glow), transparent 65%);
  }
  /* Fine dot grid, faded towards the bottom-left */
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: radial-gradient(color-mix(in srgb, var(--text) 16%, transparent) 1px, transparent 1px);
    background-size: 26px 26px;
    -webkit-mask-image: radial-gradient(70% 110% at 78% 0%, black 0%, transparent 72%);
    mask-image: radial-gradient(70% 110% at 78% 0%, black 0%, transparent 72%);
    pointer-events: none;
  }
  .hero-inner {
    position: relative;
    display: flex;
    align-items: center;
    gap: 3rem;
  }

  .hero-avatar-wrap {
    position: relative;
    flex-shrink: 0;
  }
  .hero-avatar {
    width: 180px;
    height: 180px;
    border-radius: 22px;
    object-fit: cover;
    box-shadow: var(--shadow-hover);
    position: relative;
    z-index: 1;
  }
  /* Offset frame behind the portrait */
  .hero-avatar-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    border: 1.5px solid color-mix(in srgb, var(--accent) 55%, transparent);
    border-radius: 22px;
    transform: translate(11px, 11px);
  }

  .hero-hello { margin-bottom: 0.4rem; }
  .hero-name {
    font-size: clamp(2.3rem, 5.5vw, 3.3rem);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }
  .hero-tagline {
    font-size: 1.14rem;
    font-weight: 480;
    margin-bottom: 0.3rem;
  }
  .hero-affiliation {
    color: var(--text-muted);
    font-size: 0.98rem;
  }
  .hero-affiliation em {
    font-family: var(--font-serif);
    font-size: 1.05em;
  }
  .hero-sep {
    margin: 0 0.5rem;
    color: var(--text-faint);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }
  .hero-social-row {
    display: inline-flex;
    gap: 0.55rem;
  }
  .hero-social {
    display: grid;
    place-items: center;
    width: 2.45rem;
    height: 2.45rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--bg-surface);
    color: var(--text-muted);
    box-shadow: var(--shadow);
    transition: color 0.18s ease, border-color 0.18s ease, transform 0.18s ease, box-shadow 0.18s ease;
  }
  .hero-social:hover {
    color: var(--accent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    transform: translateY(-2px);
    box-shadow: var(--shadow-hover);
  }

  @media (max-width: 680px) {
    .hero { padding: 3.4rem 0 2.6rem; }
    .hero-inner {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }
    .hero-avatar { width: 144px; height: 144px; }
    .hero-avatar-wrap::before { transform: translate(9px, 9px); }
    .hero-actions { justify-content: center; }
    .hero-affiliation em { display: inline-block; }
  }
</style>
