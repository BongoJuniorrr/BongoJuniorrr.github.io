---
import Icon from './Icon.astro';
import { formatAuthors } from '../lib/utils';

interface Props {
  pub: {
    title: string;
    authors: string[];
    venue: string;
    year: number;
    links?: Record<string, string>;
    abstract?: string;
  };
}
const { pub } = Astro.props;

const linkIcons: Record<string, string> = {
  pdf: 'pdf',
  arxiv: 'arxiv',
  code: 'code',
};
const links = Object.entries(pub.links ?? {}).filter(([, url]) => url);
---

<article class="pub reveal">
  <h3 class="pub-title">{pub.title}</h3>
  <p class="pub-authors" set:html={formatAuthors(pub.authors)} />
  <p class="pub-venue">
    <em>{pub.venue}</em> · {pub.year}
  </p>
  {(links.length > 0 || pub.abstract) && (
    <div class="pub-links">
      {links.map(([kind, url]) => (
        <a class="badge-link" href={url} target="_blank" rel="noopener">
          <Icon name={linkIcons[kind] ?? 'external'} size={13} />
          {kind === 'arxiv' ? 'arXiv' : kind.toUpperCase() === kind ? kind : kind[0].toUpperCase() + kind.slice(1)}
        </a>
      ))}
    </div>
  )}
  {pub.abstract && (
    <details class="pub-abstract">
      <summary>Abstract</summary>
      <p>{pub.abstract}</p>
    </details>
  )}
</article>

<style>
  .pub {
    padding: 1.1rem 0 1.2rem;
    border-bottom: 1px solid var(--border);
  }
  .pub:last-child { border-bottom: none; }
  .pub-title {
    font-size: 1.12rem;
    margin-bottom: 0.25rem;
  }
  .pub-authors {
    font-size: 0.92rem;
    color: var(--text-muted);
  }
  .pub-authors :global(strong) { color: var(--text); }
  .pub-venue {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-top: 0.1rem;
  }
  .pub-links {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-top: 0.55rem;
  }
  .pub-abstract {
    margin-top: 0.6rem;
    font-size: 0.92rem;
  }
  .pub-abstract summary {
    cursor: pointer;
    color: var(--accent);
    font-weight: 550;
    font-size: 0.85rem;
    width: fit-content;
  }
  .pub-abstract p {
    margin-top: 0.5rem;
    color: var(--text-muted);
    padding-left: 0.9rem;
    border-left: 2px solid var(--border);
  }
</style>
