---
import site from '../data/site.json';
---

<footer class="footer">
  <p class="muted">{site.footer_text}</p>
  <a class="back-to-top" href="#top" aria-label="Back to top">Top ↑</a>
</footer>

<style>
  .footer {
    margin-top: 4.5rem;
    padding: 1.8rem 0 2.4rem;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    font-size: 0.83rem;
  }
  .back-to-top { color: var(--text-muted); font-weight: 540; }
  .back-to-top:hover { color: var(--accent); }
</style>
