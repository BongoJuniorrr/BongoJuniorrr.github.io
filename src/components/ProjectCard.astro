---
import Icon from './Icon.astro';

interface Props {
  project: {
    name: string;
    description: string;
    tags?: string[];
    links?: { github?: string; demo?: string };
    image?: string;
  };
}
const { project } = Astro.props;
---

<article class="card project reveal">
  {project.image && <img class="project-img" src={project.image} alt={project.name} loading="lazy" />}
  <h3 class="project-name">{project.name}</h3>
  <p class="project-desc">{project.description}</p>
  {project.tags && project.tags.length > 0 && (
    <div class="project-tags">
      {project.tags.map((t) => <span class="chip">{t}</span>)}
    </div>
  )}
  <div class="project-links">
    {project.links?.github && (
      <a class="badge-link" href={project.links.github} target="_blank" rel="noopener">
        <Icon name="github" size={13} /> Code
      </a>
    )}
    {project.links?.demo && (
      <a class="badge-link" href={project.links.demo} target="_blank" rel="noopener">
        <Icon name="external" size={13} /> Demo
      </a>
    )}
  </div>
</article>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .project-img {
    border-radius: 8px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    margin-bottom: 0.3rem;
  }
  .project-name { font-size: 1.1rem; }
  .project-desc {
    font-size: 0.92rem;
    color: var(--text-muted);
    flex: 1;
  }
  .project-tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .project-links {
    display: flex;
    gap: 0.45rem;
    margin-top: 0.2rem;
  }
</style>
