---
import Icon from './Icon.astro';

interface Props {
  project: {
    name: string;
    description: string;
    tags?: string[];
    links?: { github?: string; demo?: string };
    image?: string;
  };
}
const { project } = Astro.props;
---

<article class="card project reveal">
  {project.image && <img class="project-img" src={project.image} alt={project.name} loading="lazy" />}
  <div class="project-head">
    <span class="project-glyph"><Icon name="code" size={17} /></span>
    <div class="project-head-links">
      {project.links?.github && (
        <a href={project.links.github} target="_blank" rel="noopener" aria-label={`${project.name} on GitHub`} title="Source code">
          <Icon name="github" size={17} />
        </a>
      )}
      {project.links?.demo && (
        <a href={project.links.demo} target="_blank" rel="noopener" aria-label={`${project.name} demo`} title="Live demo">
          <Icon name="external" size={17} />
        </a>
      )}
    </div>
  </div>
  <h3 class="project-name">{project.name}</h3>
  <p class="project-desc">{project.description}</p>
  {project.tags && project.tags.length > 0 && (
    <div class="project-tags">
      {project.tags.map((t) => <span class="project-tag">{t}</span>)}
    </div>
  )}
</article>

<style>
  .project {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .project-img {
    border-radius: 9px;
    aspect-ratio: 16 / 9;
    object-fit: cover;
    margin-bottom: 0.3rem;
    border: 1px solid var(--border);
  }
  .project-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.15rem;
  }
  .project-glyph {
    display: grid;
    place-items: center;
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 10px;
    background: var(--accent-soft);
    color: var(--accent);
  }
  .project-head-links {
    display: flex;
    gap: 0.65rem;
  }
  .project-head-links a {
    color: var(--text-faint);
    line-height: 0;
    transition: color 0.15s ease;
  }
  .project-head-links a:hover { color: var(--accent); }

  .project-name {
    font-size: 1.14rem;
  }
  .project-desc {
    font-size: 0.91rem;
    color: var(--text-muted);
    flex: 1;
  }
  .project-tags {
    display: flex;
    gap: 0.35rem 0.55rem;
    flex-wrap: wrap;
    margin-top: 0.2rem;
    padding-top: 0.7rem;
    border-top: 1px dashed var(--border);
  }
  .project-tag {
    font-size: 0.76rem;
    font-weight: 550;
    color: var(--text-faint);
    letter-spacing: 0.02em;
  }
  .project-tag::before {
    content: '#';
    color: var(--accent);
    opacity: 0.7;
  }
</style>
